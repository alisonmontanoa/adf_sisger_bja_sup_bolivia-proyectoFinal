{
	"name": "df_silver_personas",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_segip_personas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_personas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as string,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(ci) AS ci,\\n    TRIM(nombres) AS nombres,\\n    TRIM(apellido_paterno) AS apellido_paterno,\\n    TRIM(apellido_materno) AS apellido_materno,\\n    TRIM(fecha_nacimiento) AS fecha_nacimiento,\\n    TRIM(genero) AS genero,\\n    TRIM(estado_civil) AS estado_civil,\\n    TRIM(ci_conyuge) AS ci_conyuge,\\n    TRIM(numero_hijos) AS numero_hijos,\\n    TRIM(ci_padre) AS ci_padre,\\n    TRIM(ci_madre) AS ci_madre,\\n    TRIM(profesion) AS profesion,\\n    TRIM(nivel_estudios) AS nivel_estudios,\\n    TRIM(municipio_residencia) AS municipio_residencia,\\n    TRIM(fecha_emision) AS fecha_emision\\nFROM bronze.segip_personas\\nWHERE ci IS NOT NULL AND TRIM(ci) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(nombres = initCap(regexReplace(trim(nombres), '\\\\s+', ' ')),",
				"          apellido_paterno = initCap(regexReplace(trim(apellido_paterno), '\\\\s+', ' ')),",
				"          apellido_materno = initCap(regexReplace(trim(apellido_materno), '\\\\s+', ' ')),",
				"          nombre_completo = concat(nombres, ' ', apellido_paterno, ' ', apellido_materno),",
				"          fecha_nacimiento = coalesce(\r",
				"    toDate(fecha_nacimiento, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_nacimiento, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_nacimiento, 'MM-dd-yyyy'),\r",
				"    toDate(fecha_nacimiento, 'yyyy/MM/dd'),\r",
				"    toDate(fecha_nacimiento, 'dd-MMM-yyyy'),\r",
				"    toDate(fecha_nacimiento, 'MMMM dd, yyyy'),\r",
				"    toDate(fecha_nacimiento, \"dd 'de' MMMM 'de' yyyy\")\r",
				"\r",
				")) ~> derivedColumn1",
				"derivedColumn1 derive(genero = case(\r",
				"    in(['F','f','Femenino','femenino'], genero), 'F',\r",
				"    in(['M','m','Masculino','masculino'], genero), 'M',\r",
				"    genero\r",
				"),",
				"          estado_civil = initCap(trim(estado_civil)),",
				"          numero_hijos = iifNull(toInteger(numero_hijos), 0),",
				"          fecha_emision = coalesce(\r",
				"    toDate(fecha_emision, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_emision, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_emision, 'MM-dd-yyyy'),\r",
				"    toDate(fecha_emision, 'yyyy/MM/dd'),\r",
				"    toDate(fecha_emision, 'dd-MMM-yyyy'),\r",
				"    toDate(fecha_emision, 'MMMM dd, yyyy'),\r",
				"    toDate(fecha_emision, \"dd 'de' MMMM 'de' yyyy\")\r",
				"\r",
				")) ~> derivedColumn2",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          nombre_completo as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as integer,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as date,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci,",
				"          nombres,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          nombre_completo,",
				"          fecha_nacimiento,",
				"          genero,",
				"          estado_civil,",
				"          ci_conyuge,",
				"          numero_hijos,",
				"          ci_padre,",
				"          ci_madre,",
				"          profesion,",
				"          nivel_estudios,",
				"          municipio_residencia,",
				"          fecha_emision",
				"     )) ~> sink1"
			]
		}
	}
}