{
	"name": "df_gold_dim_paquete",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_sup_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_paquete",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          paquete_id as string,",
				"          nombre_paquete as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(18,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT\\n    paquete_id,\\n    nombre AS nombre_paquete,\\n    contenido,\\n    peso_estandar_kg,\\n    costo_estimado_bs\\nFROM silver.sup_catalogo_paquetes\\nWHERE paquete_id IS NOT NULL\\n  AND TRIM(paquete_id) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_key as integer,",
				"          paquete_id as string,",
				"          nombre_paquete as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(18,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paquete_id,",
				"          nombre_paquete,",
				"          contenido,",
				"          peso_estandar_kg,",
				"          costo_estimado_bs",
				"     )) ~> sink1"
			]
		}
	}
}