{
	"name": "df_silver_sup_entregas",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as string,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(entrega_id) AS entrega_id,\\n    TRIM(boleta_id) AS boleta_id,\\n    TRIM(ci_beneficiaria) AS ci_beneficiaria,\\n    TRIM(establecimiento_id) AS establecimiento_id,\\n    TRIM(paquete_id) AS paquete_id,\\n    TRIM(paquete_nombre) AS paquete_nombre,\\n    TRIM(fecha_entrega) AS fecha_entrega,\\n    TRIM(lote_produccion) AS lote_produccion,\\n    TRIM(peso_paquete_kg) AS peso_paquete_kg,\\n    TRIM(fecha_proxima_entrega) AS fecha_proxima_entrega\\nFROM bronze.sup_entregas\\nWHERE entrega_id IS NOT NULL AND TRIM(entrega_id) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(paquete_nombre = initCap(regexReplace(trim(paquete_nombre), '\\\\s+', ' ')),",
				"          fecha_entrega = coalesce(\r",
				"    toDate(fecha_entrega, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_entrega, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_entrega, 'MM-dd-yyyy'),\r",
				"    toDate(fecha_entrega, 'yyyy/MM/dd')\r",
				")\r",
				",",
				"          peso_paquete_kg = iifNull(toDecimal(regexReplace(toString(peso_paquete_kg), '[^0-9.]', '')), 0.0),",
				"          fecha_proxima_entrega = coalesce(\r",
				"    toDate(fecha_proxima_entrega, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_proxima_entrega, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_proxima_entrega, 'MM-dd-yyyy'),\r",
				"    toDate(fecha_proxima_entrega, 'yyyy/MM/dd')\r",
				")\r",
				") ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as date,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as decimal(10,2),",
				"          fecha_proxima_entrega as date,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          entrega_id,",
				"          boleta_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          paquete_id,",
				"          paquete_nombre,",
				"          fecha_entrega,",
				"          lote_produccion,",
				"          peso_paquete_kg,",
				"          fecha_proxima_entrega",
				"     )) ~> sink1"
			]
		}
	}
}