{
	"name": "df_silver_sup_boletas",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_sup_boletas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_boletas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(boleta_id) AS boleta_id,\\n    TRIM(control_id) AS control_id,\\n    TRIM(ci_beneficiaria) AS ci_beneficiaria,\\n    TRIM(nro_boleta) AS nro_boleta,\\n    TRIM(fecha_emision) AS fecha_emision,\\n    TRIM(estado) AS estado\\nFROM bronze.sup_boletas\\nWHERE boleta_id IS NOT NULL AND TRIM(boleta_id) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(fecha_emision = coalesce(\r",
				"    toDate(fecha_emision, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_emision, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_emision, 'MM-dd-yyyy'),\r",
				"    toDate(fecha_emision, 'yyyy/MM/dd')\r",
				")\r",
				",",
				"          estado = initCap(trim(estado))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as date,",
				"          estado as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          boleta_id,",
				"          control_id,",
				"          ci_beneficiaria,",
				"          nro_boleta,",
				"          fecha_emision,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}