{
	"name": "df_gold_fact_pagos_bja",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_bja_pagos",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "lookup1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(18,2),",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source1, source2 lookup(fecha_pago == fecha,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1"
			]
		}
	}
}